rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 腕錶與網站文案：公開讀取，需登入才能寫入
    match /watches/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /site/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // 詢問單：需登入才能讀寫
    match /inquiries/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
