// 由 .github/workflows/deploy-rules.yml 在規則檔變動時自動部署到 named database 'barthon'
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 只有這個管理員帳號能寫入
    function isAdmin() {
      return request.auth != null
             && request.auth.token.email == 'fg3797@gmail.com';
    }

    // 腕錶與網站文案：公開讀取,僅管理員可寫入
    match /watches/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /site/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 瀏覽統計:訪客可累加計數(create/update),僅管理員可讀。
    // 欄位限定,值為數字/map,避免被塞入任意資料;計數類資料風險低。
    match /stats/{day} {
      allow read: if isAdmin();
      allow write: if request.resource.data.keys().hasOnly(['date','views','visitors','clicks','updated'])
                   && (!('views' in request.resource.data)    || request.resource.data.views is number)
                   && (!('visitors' in request.resource.data) || request.resource.data.visitors is number)
                   && (!('clicks' in request.resource.data)   || request.resource.data.clicks is map);
    }

    // 詢問單：訪客可送出(create),僅管理員可讀取/更新/刪除
    match /inquiries/{id} {
      allow create: if request.resource.data.keys().hasOnly(['name','contact','watch','message','date','status'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() < 100
                    && request.resource.data.contact is string
                    && request.resource.data.contact.size() > 0
                    && request.resource.data.contact.size() < 200
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() < 2000
                    && request.resource.data.watch is string
                    && request.resource.data.watch.size() < 200
                    && request.resource.data.date is string
                    && request.resource.data.status == '新';
      allow read, update, delete: if isAdmin();
    }
  }
}
